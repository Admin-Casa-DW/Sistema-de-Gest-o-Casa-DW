{
  "name": "Casa DW - Gestão",
  "short_name": "Casa DW",
  "description": "Sistema de gestão residencial Casa DW",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#2c3e50",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "/logo-dw.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/logo-dw.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/share-scan",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "files": [
        {
          "name": "documento",
          "accept": ["application/pdf", ".pdf", "image/*", ".jpg", ".jpeg", ".png"]
        }
      ]
    }
  }
}
