
// ===== VERIFICAÇÃO DE PERMISSÃO FROTA =====
function checkFrotaPerm(action) {
    if (window.perm && !window.perm('frota', action)) {
        alert('Você não tem permissão para ' + action + ' na Frota.');
        return false;
    }
    return true;
}

function applyFrotaPermissions() {
    const canIncluir  = !window.perm || window.perm('frota', 'incluir');
    const canEditar   = !window.perm || window.perm('frota', 'editar');
    const canExcluir  = !window.perm || window.perm('frota', 'excluir');

    // Ocultar botão de adicionar veículo
    ['addVehicleBtn', 'addVehicle', 'btnAddVehicle'].forEach(id => {
        const el = document.getElementById(id);
        if (el) { el.style.display = canIncluir ? '' : 'none'; }
    });

    if (!canEditar || !canExcluir) {
        if (!document.getElementById('frotaPermStyle')) {
            const s = document.createElement('style');
            s.id = 'frotaPermStyle';
            s.textContent = `
                ${!canEditar  ? '.btn-edit-vehicle, .vehicle-edit-btn { display:none!important; }' : ''}
                ${!canExcluir ? '.btn-delete-vehicle, .vehicle-delete-btn { display:none!important; }' : ''}
                ${(!canEditar && !canExcluir) ? '.vehicle-actions { display:none!important; }' : ''}
            `;
            document.head.appendChild(s);
        }
    }
}

