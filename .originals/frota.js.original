const FLEET_STORAGE_KEY = 'fleetData';

// ===== FUNÇÃO PARA ADICIONAR DESPESA (INTEGRAÇÃO COM DASHBOARD) =====
// Esta função permite que o módulo Frota adicione despesas diretamente no sistema financeiro
if (typeof window.addExpenseFromExternal !== 'function') {
    window.addExpenseFromExternal = async function(expenseData) {
        try {
            console.log('📝 [Frota] Adicionando despesa ao Dashboard:', expenseData);

            // Validar campos obrigatórios
            if (!expenseData.date || !expenseData.description || !expenseData.amount) {
                throw new Error('Campos obrigatórios faltando: date, description, amount');
            }

            // Criar objeto de despesa
            const expense = {
                date: expenseData.date,
                description: expenseData.description,
                category: expenseData.category || 'Outros',
                supplier: expenseData.supplier || '',
                amount: parseFloat(expenseData.amount),
                paymentMethod: expenseData.paymentMethod || 'Pix',
                dueDate: expenseData.dueDate || expenseData.date,
                notes: expenseData.notes || '',
                receiptPDF: expenseData.receiptPDF || null
            };

            // Determinar mês a partir da data
            const month = expense.date ? parseInt(expense.date.substring(5, 7)) - 1 : new Date().getMonth();

            console.log('📅 Mês calculado:', month, '(índice do mês no array)');

            // Verificar se CloudStorage está disponível
            if (window.CloudStorage) {
                console.log('☁️ Usando CloudStorage para salvar despesa');

                // Carregar dados atuais da nuvem
                const financialData = await window.CloudStorage.loadAll();

                if (!financialData) {
                    throw new Error('Erro ao carregar dados financeiros da nuvem');
                }

                // Garantir que a estrutura existe
                if (!financialData.expenses) {
                    financialData.expenses = {};
                    for (let i = 0; i < 12; i++) {
                        financialData.expenses[i] = [];
                    }
                }

                // Garantir que o array do mês existe
                if (!financialData.expenses[month]) {
                    console.log('🆕 Criando array para mês', month);
                    financialData.expenses[month] = [];
                }

                // Adicionar despesa ao mês correto
                financialData.expenses[month].push(expense);

                console.log('✅ Despesa adicionada ao mês', month);
                console.log('📊 Total de despesas no mês:', financialData.expenses[month].length);

                // Salvar na nuvem
                const saved = await window.CloudStorage.saveAll(financialData);

                if (saved) {
                    console.log('☁️ Despesa salva na nuvem com sucesso!');
                    return true;
                } else {
                    throw new Error('Erro ao salvar despesa na nuvem');
                }
            } else {
                console.warn('⚠️ CloudStorage não disponível, usando localStorage');

                // Fallback: usar localStorage
                let financialData = JSON.parse(localStorage.getItem('financialData') || '{}');

                if (!financialData.expenses) {
                    financialData.expenses = {};
                    for (let i = 0; i < 12; i++) {
                        financialData.expenses[i] = [];
                    }
                }

                if (!financialData.expenses[month]) {
                    financialData.expenses[month] = [];
                }

                financialData.expenses[month].push(expense);
                localStorage.setItem('financialData', JSON.stringify(financialData));

                console.log('💾 Despesa salva no localStorage (fallback)');
                return true;
            }
        } catch (error) {
            console.error('❌ Erro ao adicionar despesa externa:', error);
            throw error;
        }
    };
    console.log('✅ Função addExpenseFromExternal registrada no módulo Frota');
}

